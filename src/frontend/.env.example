# Copy this file to `.env` (gitignored) and fill in the empty values.
#
# Why `.env` and not `.env.local`?
#   Next.js reads `.env.local` AND `.env`. Prisma CLI only reads `.env`.
#   Using a single `.env` keeps both happy with no duplication.

# ---- Database ----
# Matches docker-compose.yml's published port (5435 to avoid conflicts
# with habit-tracking-1 @ 5434, mindmeister @ 5433, system Postgres @ 5432).
DATABASE_URL=postgresql://timeclock:t1m3cl0ck-d3v-2026@localhost:5435/timeclock

# ---- NextAuth ----
NEXTAUTH_URL=http://localhost:3000
AUTH_TRUST_HOST=true

# Generate with:  node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
NEXTAUTH_SECRET=
AUTH_SECRET=

# ---- Google OAuth ----
# Reuse the shared "CSFloat Tracker" OAuth client (same one habits/mindmeister
# use). Pull the values from the cluster:
#   ssh 5560 'sudo kubectl -n timeclock get secret google-oauth \
#     -o jsonpath="{.data.client-id}" | base64 -d'
#   ssh 5560 'sudo kubectl -n timeclock get secret google-oauth \
#     -o jsonpath="{.data.client-secret}" | base64 -d'
# http://localhost:3000/api/auth/callback/google is already authorized.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ---- Allowlist ----
# Public read is open to all. Only emails in this CSV (or in the AllowedEmail
# DB table) can SIGN IN. The email matching ADMIN_EMAIL gets the ADMIN role
# on first sign-in; only ADMINs can write via the API.
ALLOWED_EMAILS=haianhletruonh@gmail.com
ADMIN_EMAIL=haianhletruonh@gmail.com
